# Supabase (Frontend)
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase (Server-side only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# MT5 Password Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MT5_ENCRYPTION_KEY=

# Email Reports (ADV-009) — get a free API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=IB Portal <reports@yourdomain.com>

# App URL (used in email links)
PUBLIC_APP_URL=https://yourdomain.com

# Sentry Error Tracking (DEPLOY-002)
PUBLIC_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
PUBLIC_SENTRY_ENVIRONMENT=development
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
SENTRY_ENVIRONMENT=development
SENTRY_ORG=your-org
SENTRY_PROJECT=ib-portal
SENTRY_AUTH_TOKEN=sntrys_xxx

# Upstash Redis (SCALE-001) — for distributed rate limiting across instances
# Get credentials at https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx
